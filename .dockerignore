# Node modules - npm ci installs fresh in container
frontend/node_modules

# Git
.git
.gitignore

# Build artifacts
frontend/dist
worker/dist
worker/build
worker/*.egg-info

# Python cache
__pycache__
*.pyc
*.pyo

# Logs and temp files
*.log
tmp/

# IDE
.vscode
.idea

# Local dev config override: a gitignored symlink to a host-absolute path
# (/home/<user>/.dispatcher/etc/config.json). It dangles inside the build
# context and breaks vite's public/ dir copy. The container generates its own
# config.json at build time and gets API_URL injected by the entrypoint.
frontend/public/config.local.json
